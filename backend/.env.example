# Copy this file to .env and fill in your actual values.
# NEVER commit a .env file or real credentials to version control.

SUPABASE_URL=https://your-supabase-project-url
DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:6543/your-db-name
SUPABASE_ANON_KEY=your-supabase-anon-key-placeholder
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-placeholder
GEMINI_API_KEY=your-gemini-api-key-placeholder
GEMINI_MODEL=gemini-2.0-flash
EXPO_PUSH_ACCESS_TOKEN=optional
PORT=8000
MONTHLY_CO2_TARGET_KG=5000
CARBON_CREDIT_PRICE_INR=800
INDIA_BASELINE_CO2_PER_KM=0.9
